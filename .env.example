# Secrets only. Structured config lives in config/horizon.yaml (see ADR-0003).

# OpenAI API key for the Reasoner (cheap + deep tiers), embeddings, and TTS.
# See ADR-0012 / ADR-0018 / ADR-0020.
OPENAI_API_KEY=sk-...

# Telegram bot token (only if telegram.enabled in config/horizon.yaml). See ADR-0019.
TELEGRAM_BOT_TOKEN=

# Database. Defaults to a local SQLite file; point at a hosted Turso libsql://…
# URL + its auth token for a remote DB (ADR-0031, docs/DEPLOY-RENDER.md).
# DB_URL=file:./data/horizon.db
# DB_AUTH_TOKEN=

# Chat web-search fallback, only when telegram.chat.webSearch.provider: tavily (ADR-0029).
# TAVILY_API_KEY=

# HTTP server (optional). PORT defaults to 3000; HOST defaults to 127.0.0.1 —
# set HOST=0.0.0.0 to expose the viewer behind a proxy (ADR-0023).
# PORT=3000
# HOST=127.0.0.1
