{
  "name": "project-horizon",
  "version": "0.1.0",
  "description": "Autonomous intelligence agent — server-side executive editor (Phase 1)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "@hono/node-server": "^1.13.0",
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.39.0",
    "fast-xml-parser": "^4.5.0",
    "hono": "^4.6.0",
    "openai": "^4.77.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
